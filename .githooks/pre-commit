#!/usr/bin/env bash
# AgenticWorkforce pre-commit hook
# Install: ./scripts/install-hooks.sh

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# CQI threshold — calibrated to phase of build, raised as the codebase matures:
#   55 (ADEQUATE) — scaffolding through Phase 2 (current)
#   65 (GOOD)     — after Phase 3 (API core lands, tests exist)
#   75 (GOOD+)    — after Phase 10 (integration tests cover the stack)
CQI_MIN=55
SLN=AgenticWorkforce.slnx

echo "[ pre-commit ] Running checks..."

# -- 0. Secret scanning (gitleaks) --
if command -v gitleaks &>/dev/null; then
  echo "  -> gitleaks"
  if ! gitleaks protect --staged --exit-code 1 --no-banner --redact --log-level error; then
    echo "  x Secrets detected in staged files. Commit aborted."
    echo "    Run: gitleaks protect --staged --verbose to see details."
    exit 1
  fi
else
  echo "  [WARN] gitleaks not installed — secret scanning skipped. Install: brew install gitleaks"
fi

# -- 1. Build --
# Note: --verbosity quiet (not -q). In .NET 10, -q is interpreted as MSBuild's
# --question flag, which asks "is the build up to date" and exits non-zero
# whenever any target would actually run. That's not what we want.
echo "  -> build"
if ! dotnet build "$SLN" --nologo --verbosity quiet; then
  echo "  x Build failed. Commit aborted."
  exit 1
fi

# -- 2. Tests --
echo "  -> tests"
if ! dotnet test "$SLN" --nologo --verbosity quiet --no-build; then
  echo "  x Tests failed. Commit aborted."
  exit 1
fi

# -- 3. CQI — fast mode (no coverage, no semgrep) --
echo "  -> CQI"
CQI_JSON=$(./scripts/code-quality.sh "$SLN" --json --no-coverage --no-semgrep 2>/dev/null)

CQI=$(echo "$CQI_JSON"  | python3 -c "import json,sys; print(int(json.load(sys.stdin)['cqi']))")
BAND=$(echo "$CQI_JSON" | python3 -c "import json,sys; print(json.load(sys.stdin)['band'])")
COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
NOW=$(date -u +"%Y-%m-%d %H:%M UTC")

# -- 4. Write .codemap/quality.md --
mkdir -p .codemap
python3 - "$CQI_JSON" "$COMMIT" "$NOW" "$CQI_MIN" > .codemap/quality.md <<'PY'
import json, sys
raw, commit, now, min_score = sys.argv[1], sys.argv[2], sys.argv[3], int(sys.argv[4])
d = json.loads(raw)
cqi  = d['cqi']
band = d['band']
dims = d['dimensions']
kloc = d.get('kloc', '?')

lines = [
    f"# C# Code Quality Index (CQI)\n",
    f"**Score: {cqi} / 100 — {band.title()}**  ",
    f"*(minimum: {min_score} | commit: `{commit}` | {now})*\n",
    f"| Metric | Value |",
    f"|--------|------:|",
    f"| KLOC   | {kloc} |\n",
    f"## Dimensions\n",
    f"| Dimension | Score |",
    f"|-----------|------:|",
]
for name, score in sorted(dims.items(), key=lambda x: -x[1]):
    lines.append(f"| {name} | {score} |")

lines += [
    "",
    "## Bands",
    "",
    "| Band | Range |",
    "|------|-------|",
    "| Excellent | 80-100 |",
    "| Good | 65-79 |",
    "| Adequate | 55-64 |",
    "| Acceptable | 31-54 |",
    "| Poor | 0-30 |",
    "",
    "> Auto-generated by `scripts/code-quality.sh`. Do not edit manually.",
]
print('\n'.join(lines))
PY

echo "$CQI_JSON" > .codemap/quality.json

# -- 4b. Regenerate codemap (.codemap/map.md) so subsequent phases have a
#         fresh type/method inventory to consult before making changes.
#         Failure is FATAL — a stale codemap is the exact contract we hand
#         to the next phase agent, and silent staleness causes duplicated
#         work and stale-data bugs. Fix the codemap tool before retrying.
echo "  -> codemap"
if ! CODEMAP_OUT=$(./scripts/codemap.sh 2>&1); then
  echo "  x Codemap regeneration failed. Commit aborted."
  echo "    The hook will not silently publish a stale .codemap/map.md."
  echo "    Output:"
  echo "$CODEMAP_OUT" | sed 's/^/    /'
  exit 1
fi

git add .codemap/quality.md .codemap/quality.json .codemap/map.md

# -- 5. Gate --
if [ "$CQI" -lt "$CQI_MIN" ]; then
  echo "  x CQI ${CQI} (${BAND}) is below minimum ${CQI_MIN}. Commit aborted."
  echo "    Run: ./scripts/code-quality.sh ${SLN} to see details."
  exit 1
fi

echo "  + CQI ${CQI} (${BAND}) — meets minimum ${CQI_MIN}"
echo "[ pre-commit ] All checks passed."
