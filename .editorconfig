root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# EF Core auto-generates migration files; suppress analyzer rules that target
# patterns we cannot reasonably fix without hand-editing scaffolded code.
[**/Migrations/*.cs]
dotnet_diagnostic.CA1861.severity = none
